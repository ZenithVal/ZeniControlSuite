<MudPaper Outlined Class="pa-3" Style="background-color: rgba(0,0,0,.18);">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
        <MudText Typo="Typo.subtitle2">Output</MudText>
        <MudSpacer />
        <MudText Typo="Typo.subtitle2">@OutputPercent</MudText>
    </div>

    <canvas @ref="graphCanvas" style="width:100%; height:150px; display:block; border:1px solid rgba(255,255,255,.16); border-radius:8px; background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.01));"></canvas>
</MudPaper>
