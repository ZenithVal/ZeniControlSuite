@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ZeniControlSuite.Authentication
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ZeniControlSuite.Services.Service_PageAccess PageAccess
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Zeni Control Suite</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">

            <AuthorizeView>
                <Authorized>
                    <div class="user-info-container">

                        <MudAvatar>
                            <MudImage src="@context.GetAvatar()" Alt="User Avatar"></MudImage>
                        </MudAvatar>

                        <div class="user-info-text">
                            <div>@context.GetUserName()</div>
                            <a href="api/account/logout" style="width: min-content">Log Out</a>
                        </div>
                    </div>

                    <div style="height: 8px"></div>

                    @foreach (var accessPage in PageAccess.Pages)
                    {
                        if (PageAccess.UserCanSeeNav(context.User, accessPage))
                        {
                            <div class="nav-item px-3" style="@AdminPageOutline(context.User, accessPage.Enabled)">
                                <NavLink class="nav-link" href="@accessPage.Path.TrimStart('/')">
                                    <MudIcon Icon="@PageIcon(accessPage.Key)"></MudIcon>
                                    <span style="padding: 0 8px;">@accessPage.Label</span>
                                </NavLink>
                            </div>
                        }
                    }

                    @if (context.User.IsInRole("Admin") || context.User.IsInRole("LocalHost"))
                    {
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="Settings">
                                <MudIcon Icon="@Icons.Material.Filled.Settings"></MudIcon>
                                <span style="padding: 0 8px;">Settings</span>
                            </NavLink>
                        </div>

                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="Logs">
                                <MudIcon Icon="@Icons.Material.Filled.List"></MudIcon>
                                <span style="padding: 0 8px;">Logs</span>
                            </NavLink>
                        </div>
                    }

                    @if (ZeniControlSuite.Components.Pages.Settings.AppDebug)
                    {
                        <br />
                        <div class="nav-item px-3">
                            <MudDivider />
                            <br />
                            <span style="padding: 0 8px;">Roles Debug:</span>
                            @foreach (var role in context.GetRoles())
                            {
                                <div class="nav-item px-3">
                                    <MudIcon Icon="@Icons.Material.Filled.Security"></MudIcon>
                                    <span style="padding: 0 8px;">@role</span>
                                </div>
                            }
                        </div>
                    }

                </Authorized>

                <NotAuthorized>
                    <NavLink class="nav-link" href="Login">
                        <MudIcon Icon="@Icons.Material.Filled.Login"></MudIcon>
                        <span style="padding: 0 8px;">Log in</span>
                    </NavLink>
                </NotAuthorized>

            </AuthorizeView>
        </div>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        PageAccess.OnPageAccessChanged += OnPageAccessChanged;
    }

    private void OnPageAccessChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private static string AdminPageOutline(System.Security.Claims.ClaimsPrincipal user, bool enabled)
    {
        if (!user.IsInRole("Admin") && !user.IsInRole("LocalHost"))
        {
            return string.Empty;
        }

        var color = enabled ? "rgba(76, 175, 80, .95)" : "rgba(244, 67, 54, .95)";
        return $"border: 2px solid {color}; border-radius: 6px; margin: 2px 0 6px 0;";
    }

    private static string PageIcon(string key)
    {
        return key switch
        {
            "AvatarControls" => Icons.Material.Filled.WifiTethering,
            "AvatarSelect" => Icons.Material.Filled.Colorize,
            "GamesPoints" => Icons.Material.Filled.Games,
            "Bindings" => Icons.Material.Filled.Lock,
            "Devices" => Icons.Material.Filled.SettingsRemote,
            "Shockers" => Icons.Material.Filled.Bolt,
            _ => Icons.Material.Filled.Circle
        };
    }

    public void Dispose()
    {
        PageAccess.OnPageAccessChanged -= OnPageAccessChanged;
    }
}
