@page "/AvatarSelect"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using ZeniControlSuite.Authentication
@using ZeniControlSuite.Models
@using MudBlazor.Services
@using MudBlazor.Utilities
@attribute [Authorize(Roles = "Admin,Visitor")]

<PageTitle>Avatar Select</PageTitle>

<div class="d-flex align-center justify-space-between flex-wrap gap-3">
    <MudText Typo="Typo.h4">Avatar Select</MudText>
</div>

<MudDivider Class="my-4" />

<AuthorizeView>
    <Authorized>
        @{ var isAdminUser = context.User.IsInRole("Admin") || context.User.IsInRole("LocalHost"); }
        <MudGrid>
            <MudItem xs="12" lg="8">
                <MudPaper Outlined Class="pa-3 mb-3 bg-transparent">
                    <div class="d-flex align-center flex-wrap gap-2">
                        @if (isAdminUser)
                        {
                            <MudButton Variant="@(avatarSelectEditMode ? Variant.Filled : Variant.Outlined)" Color="Color.Info" Style="text-transform:none" OnClick="ToggleAvatarSelectEditMode">
                                @(avatarSelectEditMode ? "Exit Edit Mode" : "Edit Mode")
                            </MudButton>
                            <MudButton Variant="@(adminPanelExpand ? Variant.Filled : Variant.Outlined)" Color="Color.Secondary" Style="text-transform:none" OnClick="ToggleAdminPanel">
                                @(adminPanelExpand ? "Hide Settings" : "Settings")
                            </MudButton>
                        }

                        @if (!AvatarsService.avatarSelectFree)
                        {
                            <MudButton Variant="Variant.Outlined" Style="text-transform:none" Color="Color.Success">Points: @PointsService.pointsDisplay</MudButton>
                        }

                        @if (AvatarsService.Trapped)
                        {
                            string endTime = AvatarsService.TrapEndTime.ToString("HH:mm");
                            bool canAffordAddTime = PointsService.pointsTotal >= 2;
                            <MudAlert Dense="true" Variant="Variant.Outlined" Severity="Severity.Error">Avatar locked until @endTime</MudAlert>
                            <MudButton Variant="Variant.Filled" Style="text-transform:none" Color="Color.Success" Disabled="!canAffordAddTime" OnClick="IncreaseTrapTimer">Add Time - 2✦</MudButton>
                            <MudButton Variant="Variant.Filled" Style="text-transform:none" Color="Color.Primary" OnClick="DecreaseTrapTimer">Remove Time + 2✦</MudButton>
                        }
                    </div>

                    @if (isAdminUser && adminPanelExpand)
                    {
                        <MudDivider Class="my-3" />
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudSwitch Value="@AvatarsService.avatarSelectEnabled" ValueChanged="@((bool value) => UpdateAvatarSelectEnabled(value))" Label="Avatar Select Allowed" Color="Color.Info" />
                                <MudSwitch Value="@AvatarsService.avatarSelectFree" ValueChanged="@((bool value) => UpdateAvatarSelectFree(value))" Label="Avatar Select Free" Color="Color.Warning" />
                                <MudSwitch Value="@AvatarsService.Trapped" ValueChanged="@((bool value) => UpdateAvatarTrapped(value))" Label="Avatar Trapped" Color="Color.Error" />
                                <MudNumericField T="double" Value="@AvatarsService.avatarSelectCostMulti" ValueChanged="@((double value) => UpdateAvatarCostMultiplier(value))" Label="Avatar Cost Multiplier" Color="Color.Info" Step="0.25" Min="1.0" />
                            </MudItem>
                        </MudGrid>
                    }
                </MudPaper>

                <MudPaper Outlined Class="pa-3 bg-transparent">
                    <MudGrid Spacing="3" Justify="Justify.FlexStart">
                        @foreach (Avatar avatar in AvatarsService.avatars)
                        {
                            if (!ShouldShowAvatarCard(avatar, isAdminUser))
                            {
                                continue;
                            }

                            <MudItem>
                                <MudPaper Style="width: 230px; padding: 12px;" Class="mt-2 justify-center align-start p-2 border-1">
                                    <div style="width: 100%; min-height: 32px; background: rgba(0, 0, 0, 0.0)">
                                        <MudText Typo="Typo.h6" Align="Align.Center">@AvatarCardTitle(avatar)</MudText>
                                    </div>

                                    <MudImage Width="207" Class="rounded-lg" Src="@avatar.Thumbnail" Alt="@avatar.Name" />

                                    <div style="height: 4px"></div>
                                    <MudDivider />
                                    <div style="height: 4px"></div>

                                    @if (avatarSelectEditMode && isAdminUser)
                                    {
                                        <MudPaper Class="pa-2 mb-2" Outlined="true">
                                            <MudTextField T="string" Value="@avatar.Name" ValueChanged="@((string value) => UpdateAvatarName(avatar, value))" Label="Avatar Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                            <MudTextField T="string" Value="@avatar.IconName" ValueChanged="@((string value) => UpdateAvatarIconName(avatar, value))" Label="Icon Source Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                            <MudNumericField T="double" Value="@avatar.Cost" ValueChanged="@((double value) => UpdateAvatarCost(avatar, value))" Label="Price" Min="0" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                            <MudSwitch Value="@avatar.Selectable" ValueChanged="@((bool value) => UpdateAvatarSelectable(avatar, value))" Label="Selectable" Color="Color.Info" />
                                            <MudSwitch Value="@avatar.Available" ValueChanged="@((bool value) => UpdateAvatarAvailable(avatar, value))" Label="Available" Color="Color.Success" />
                                            <div class="d-flex gap-2 mb-2">
                                                <MudButton Variant="Variant.Outlined" Color="Color.Default" Style="flex:1; text-transform:none" OnClick="@(() => MoveAvatar(avatar, -1))">Up</MudButton>
                                                <MudButton Variant="Variant.Outlined" Color="Color.Default" Style="flex:1; text-transform:none" OnClick="@(() => MoveAvatar(avatar, 1))">Down</MudButton>
                                            </div>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true" OnClick="@(() => SelectAvatar(avatar))">Select Now</MudButton>
                                        </MudPaper>
                                    }

                                    @if (AvatarsService.avatarSelectFree)
                                    {
                                        @if (AvatarsService.selectedAvatar == avatar)
                                        {
                                            <MudButton Variant="Variant.Outlined" Style="width: 100%; height: 37px; text-transform:none; font-size: larger;" Color="Color.Error" Disabled="true">Currently Selected</MudButton>
                                        }
                                        else
                                        {
                                            <MudButton Variant="Variant.Filled" Style="width: 100%; height: 37px; text-transform:none; font-size: larger;" Color="Color.Info" Disabled="@(!CanSelectAvatar(avatar, isAdminUser))" OnClick="@(() => SelectAvatar(avatar))">Select Avatar</MudButton>
                                        }
                                    }
                                    else
                                    {
                                        double cost = avatar.Cost * AvatarsService.avatarSelectCostMulti;
                                        bool canAffordAvatar = cost <= PointsService.pointsTotal;
                                        @if (AvatarsService.selectedAvatar == avatar)
                                        {
                                            if (AvatarsService.TrapTimerRunning)
                                            {
                                                <MudButton Variant="Variant.Filled" Style="width: 100%; height: 37px; text-transform:none; font-size: larger;" Color="Color.Warning" Disabled="true">Avatar Locked</MudButton>
                                            }
                                            else
                                            {
                                                bool canAffordAddTime = PointsService.pointsTotal >= 2;
                                                <MudButton Variant="Variant.Filled" Style="width: 100%; height: 37px; text-transform:none; font-size: larger;" Color="Color.Secondary" Disabled="!canAffordAddTime" OnClick="@(() => IncreaseTrapTimer())">Lock Avatar - 2⭐</MudButton>
                                            }
                                        }
                                        else
                                        {
                                            <MudButton Variant="Variant.Filled" Style="width: 100%; height: 37px; text-transform:none; font-size: larger;" Color="@(canAffordAvatar ? Color.Info : Color.Error)" Disabled="@(!canAffordAvatar && !isAdminUser)" OnClick="@(() => PurchaseAvatar(avatar))">Select - @cost✦</MudButton>
                                        }
                                    }
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" lg="4">
                <Panel_LogsAvatars />
            </MudItem>
        </MudGrid>
    </Authorized>
</AuthorizeView>
