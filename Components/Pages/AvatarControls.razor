@page "/AvatarControls"
@using Microsoft.AspNetCore.Authorization
@using ZeniControlSuite.Models
@using MudBlazor.Utilities
@attribute [Authorize(Roles = "Admin,Visitor")]

<PageTitle>Avatar Controls</PageTitle>

<div class="d-flex align-center justify-space-between flex-wrap gap-3">
    <MudText Typo="Typo.h4">@AvatarsService.selectedAvatar.Name</MudText>

    @if (isAdmin)
    {
        <MudButton Variant="@(editMode ? Variant.Filled : Variant.Outlined)" Color="Color.Info" OnClick="ToggleEditMode">
            @(editMode ? "Exit Edit Mode" : "Edit Mode")
        </MudButton>
    }
</div>

<MudDivider Class="my-4" />

@if (!AvatarsService.avatarsLoaded)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (!AvatarsService.SelectedAvatarIsValid)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        No valid avatar selected.
    </MudAlert>

    @if (isAdmin && editMode)
    {
        <MudPaper Class="pa-4 mt-4" Outlined="true">
            <MudText Typo="Typo.h6">Current Worn Avatar</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">ID: @AvatarsService.CurrentWornAvatarId</MudText>

            @if (AvatarsService.CurrentAvatarInvalid)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">This avatar is marked invalid.</MudAlert>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="RemoveCurrentAvatarInvalidMark">Remove Invalid Mark</MudButton>
            }
            else
            {
                <MudTextField @bind-Value="avatarDisplayName" Label="Display Name" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 420px;" />
                <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="LoadAvatarParameters" Disabled="@loadingParameters" Class="mt-3">Load Avatar Parameters</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="AddCurrentAvatar" Class="mt-3 ml-2">Add Avatar To Controls</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="MarkCurrentAvatarInvalid" Class="mt-3 ml-2">Mark Invalid</MudButton>

                @if (!string.IsNullOrWhiteSpace(AvatarsService.LastLoadedAvatarParameterFile))
                {
                    <MudText Typo="Typo.caption" Class="d-block mt-3">Loaded: @AvatarsService.LastLoadedAvatarParameterFile</MudText>
                }
            }
        </MudPaper>
    }
}
else
{
    @if (isAdmin && editMode)
    {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.h6">Avatar Info</MudText>
                    <MudText Typo="Typo.caption">Name: @AvatarsService.selectedAvatar.Name</MudText><br />
                    <MudText Typo="Typo.caption">ID: @AvatarsService.selectedAvatar.ID</MudText><br />
                    <MudText Typo="Typo.caption">Controls: @AvatarsService.selectedAvatar.Controls.Count</MudText><br />
                    <MudText Typo="Typo.caption">Loaded parameters: @OscService.DiscoveredAvatarParameters.Count</MudText><br />
                    @if (!string.IsNullOrWhiteSpace(AvatarsService.LastLoadedAvatarParameterFile))
                    {
                        <MudText Typo="Typo.caption">Source: @AvatarsService.LastLoadedAvatarParameterFile</MudText><br />
                    }

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <MudButton Variant="@(confirmDeleteAvatar ? Variant.Filled : Variant.Outlined)" Color="Color.Error" OnClick="DeleteSelectedAvatar">
                            @(confirmDeleteAvatar ? "Confirm Delete" : "Delete")
                        </MudButton>
                        @if (confirmDeleteAvatar)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CancelDeleteSelectedAvatar">Cancel</MudButton>
                        }
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.h6">Access</MudText>
                    <MudNumericField T="int" Value="@AvatarsService.CurrentAccessLevel" ValueChanged="@((int value) => SetCurrentAccessLevel(value))" Label="Current Access Level" Min="0" Max="10" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudExpansionPanels Class="mb-4" MultiExpansion="true">
            <MudExpansionPanel Text="Avatar Setup" Expanded="false">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="LoadAvatarParameters" Disabled="@loadingParameters">Load Avatar Parameters</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="AddMatchedGlobals" Class="ml-2">Add Matched Global Controls</MudButton>

                @if (AvatarsService.GetMatchedGlobalControlsNotOnSelected().Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-4">Matched Global Controls</MudText>
                    <MudGrid Spacing="2">
                        @foreach (var control in AvatarsService.GetMatchedGlobalControlsNotOnSelected())
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <MudButton Variant="Variant.Outlined" Color="Color.Success" FullWidth="true" OnClick="@(() => AddGlobalControl(control))">@control.Name</MudButton>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudExpansionPanel>

            <MudExpansionPanel Text="Add Control From Loaded Avatar Parameters" Expanded="false">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="parameterFilter" Label="Filter Parameters" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int" @bind-Value="newToggleAccessLevel" Label="New Control Access Level" Min="0" Max="10" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int" @bind-Value="newToggleIntegerValue" Label="Integer On Value" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>

                <div style="max-height: 440px; overflow-y: auto;">
                    <MudTable Items="@FilteredLoadedParameters()" Hover="true" Class="mt-2">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Icon Name</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Address</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Name">@context.DisplayName</MudTd>
                            <MudTd DataLabel="Type">@context.Type</MudTd>
                            <MudTd DataLabel="Address">@context.Address</MudTd>
                            <MudTd>
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => AddLoadedToggle(context))">Add To Avatar</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="ml-2" OnClick="@(() => AddLoadedToggleToGlobal(context))">Add To Global</MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </MudExpansionPanel>

            <MudExpansionPanel Text="Add Existing Global Control" Expanded="false">
                <MudGrid Spacing="2">
                    @foreach (var control in AvatarsService.GetGlobalControlsNotOnSelected())
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true" OnClick="@(() => AddGlobalControl(control))">@control.Name</MudButton>
                        </MudItem>
                    }
                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Text="Global Controls" Expanded="false">
                <div style="max-height: 520px; overflow-y: auto;">
                    <MudTable Items="@AvatarsService.GlobalControls" Hover="true">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Icon Name</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Access</MudTh>
                            <MudTh>Values</MudTh>
                            <MudTh>Order</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Name">
                                <MudTextField T="string" Value="@context.Name" ValueChanged="@((string value) => RenameControl(context, value))" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudTd>
                            <MudTd DataLabel="Icon Name">
                                <MudTextField T="string" Value="@context.IconName" ValueChanged="@((string value) => SetControlIconName(context, value))" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudTd>
                            <MudTd DataLabel="Type">@context.Type</MudTd>
                            <MudTd DataLabel="Access">
                                <MudNumericField T="int" Value="@context.AccessLevel" ValueChanged="@((int value) => SetControlAccessLevel(context, value))" Min="0" Max="10" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 110px;" />
                            </MudTd>
                            <MudTd DataLabel="Values">
                                @if (context is ContTypeToggle globalToggle)
                                {
                                    if (globalToggle.Parameter.Type == ParameterType.Bool)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => InvertToggleValues(globalToggle))">Invert Values</MudButton>
                                    }
                                    else if (globalToggle.Parameter.Type == ParameterType.Int)
                                    {
                                        <MudNumericField T="int" Value="@ToggleOnValueAsInt(globalToggle)" ValueChanged="@((int value) => SetIntegerToggleValue(globalToggle, value))" Label="On Value" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 130px;" />
                                    }
                                }
                            </MudTd>
                            <MudTd DataLabel="Order">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => MoveGlobalControl(context, -1))">Up</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Class="ml-2" OnClick="@(() => MoveGlobalControl(context, 1))">Down</MudButton>
                            </MudTd>
                            <MudTd>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => RemoveGlobalControl(context))">Remove</MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }

    @if (!GetVisibleControls().Any())
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No controls are available.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="3" Justify="Justify.FlexStart">
            @foreach (AvatarControl control in GetVisibleControls())
            {
                <MudItem xs="12" sm="6" md="4" lg="3" xl="2">
                    <MudPaper Style="@ControlCardStyle(control)" Class="mt-2">
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.subtitle1">@control.Name</MudText>
                        </div>

                        @if (isAdmin && editMode)
                        {
                            <MudPaper Class="pa-2 mb-2" Outlined="true">
                                @if (AvatarsService.SelectedControlIsInheritedGlobal(control))
                                {
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-2">Inherited global control.</MudAlert>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => BreakGlobalControl(control))" Class="mb-2">Break Global</MudButton>
                                }

                                <MudTextField T="string" Value="@control.Name" ValueChanged="@((string value) => RenameControl(control, value))" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudTextField T="string" Value="@control.IconName" ValueChanged="@((string value) => SetControlIconName(control, value))" Label="Icon Name" Variant="Variant.Outlined" Margin="Margin.Dense" />

                                @if (control is ContTypeToggle editToggle)
                                {
                                    <MudText Typo="Typo.caption" Class="d-block mt-2">@editToggle.Parameter.Address</MudText>
                                    @if (editToggle.Parameter.Type == ParameterType.Bool)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => InvertToggleValues(editToggle))">Invert Values</MudButton>
                                        <MudText Typo="Typo.caption" Class="ml-2">Off: @editToggle.ValueOff / On: @editToggle.ValueOn</MudText>
                                    }
                                    else if (editToggle.Parameter.Type == ParameterType.Int)
                                    {
                                        <MudNumericField T="int" Value="@ToggleOnValueAsInt(editToggle)" ValueChanged="@((int value) => SetIntegerToggleValue(editToggle, value))" Label="Integer On Value" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    }
                                }

                                <div class="d-flex align-center justify-space-between flex-wrap gap-2 mt-2">
                                    <div style="min-width: 130px;">
                                        <MudNumericField T="int" Value="@control.AccessLevel" ValueChanged="@((int value) => SetControlAccessLevel(control, value))" Label="Access" Min="0" Max="10" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.caption">Order</MudText><br />
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(() => MoveSelectedControl(control, -1))">Up</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Class="ml-1" OnClick="@(() => MoveSelectedControl(control, 1))">Down</MudButton>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    @if (!AvatarsService.SelectedControlIsInheritedGlobal(control))
                                    {
                                        <MudButton Size="Size.Small" Variant="@(AvatarsService.SelectedControlHasGlobalNameMatch(control) ? Variant.Filled : Variant.Outlined)" Color="@(AvatarsService.SelectedControlHasGlobalNameMatch(control) ? Color.Primary : Color.Info)" OnClick="@(() => AddOrSyncControlToGlobal(control))">
                                            @(AvatarsService.SelectedControlHasGlobalNameMatch(control) ? "Sync To Global" : "Add To Global")
                                        </MudButton>
                                    }
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => RemoveSelectedControl(control))">Remove</MudButton>
                                </div>
                            </MudPaper>
                        }

                        @if (control is ContTypeButton contBut)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Info" Disabled="@(!CanUseControl(control))" FullWidth="true" OnClick="@(() => AvatarsService.SetParameterValue(contBut.Parameter))">Send</MudButton>
                        }
                        else if (control is ContTypeToggle contTog)
                        {
                            TryGetParameter(contTog.Parameter, out var param);
                            var isOn = Math.Abs(param.Value - contTog.ValueOn) < 0.001f;
                            <MudButton Style="width: 100%; height: 150px;" Variant="@(isOn ? Variant.Filled : Variant.Outlined)" Color="@(isOn ? Color.Info : Color.Default)" Disabled="@(!CanUseControl(control))" OnClick="@(() => ControlTogglePress(contTog))">
                                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="1">
                                    <MudImage Src="@control.Icon" Style="width: 72px; height: 72px; object-fit: contain;" Alt="@control.Name"></MudImage>
                                    <MudText Typo="Typo.body2">@(isOn ? "On" : "Off")</MudText>
                                </MudStack>
                            </MudButton>
                        }
                        else if (control is ContTypeRadial contRad)
                        {
                            TryGetParameter(contRad.Parameter, out var param);
                            <div class="zcs-radial-control"
                                 data-zcs-radial="true"
                                 data-address="@contRad.Parameter.Address"
                                 data-value="@Invariant(param.Value)"
                                 data-min="@Invariant(contRad.ValueMin)"
                                 data-max="@Invariant(contRad.ValueMax)"
                                 data-disabled="@BoolAttr(!CanUseControl(control))">
                                <canvas class="zcs-radial-canvas" width="190" height="170" aria-label="@control.Name"></canvas>
                                <div class="zcs-radial-readout">
                                    <MudImage Src="@control.Icon" Class="zcs-radial-center-icon" Alt="@control.Name"></MudImage>
                                    <div class="zcs-radial-number">@RoundFloat(param.Value)</div>
                                    <div class="zcs-radial-label">@control.Name</div>
                                </div>
                                <div class="zcs-radial-snapmarks">0 · 25 · 50 · 75 · 100</div>
                            </div>
                        }
                        else if (control is ContTypeHSV contHSV)
                        {
                            MudColor mudColorEstimate = AvatarsService.HSVControlToMudColor(contHSV);
                            string hexColorEstimate = mudColorEstimate.ToString(MudColorOutputFormats.Hex);
                            TryGetParameter(contHSV.ParameterHue, out var paramHue);
                            TryGetParameter(contHSV.ParameterSaturation, out var paramSat);
                            TryGetParameter(contHSV.ParameterBrightness, out var paramBri);
                            var visibleBrightness = contHSV.InvertedBrightness ? contHSV.InvertedBrightnessValue : paramBri.Value;

                            <div class="zcs-hsv-picker"
                                 data-zcs-hsv="true"
                                 data-hue-address="@contHSV.ParameterHue.Address"
                                 data-hue="@Invariant(paramHue.Value)"
                                 data-saturation="@Invariant(paramSat.Value)"
                                 data-value="@Invariant(visibleBrightness)"
                                 data-disabled="@BoolAttr(!CanUseControl(control))">
                                <div class="zcs-hsv-preview" style="background-color: @hexColorEstimate;"></div>
                                <canvas class="zcs-hsv-square" width="190" height="140" aria-label="@control.Name saturation and value"></canvas>
                                <canvas class="zcs-hsv-hue" width="190" height="24" aria-label="@control.Name hue"></canvas>
                                <div class="zcs-hsv-values">
                                    <span>H @RoundFloat(paramHue.Value)</span>
                                    <span>S @RoundFloat(paramSat.Value)</span>
                                    <span>V @RoundFloat(visibleBrightness)</span>
                                    <span>@hexColorEstimate</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption">Unsupported control type.</MudText>
                        }
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
}
