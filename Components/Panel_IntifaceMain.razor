@page "/Intiface"
@layout ZeniControlSuite.Components.Layout.NoMenuLayout
@using Microsoft.AspNetCore.Authorization
@using ZeniControlSuite.Models
@attribute [Authorize(Roles = "Admin,Visitor")]

@if (!HideForVisitor)
{
    <MudPaper Outlined Class="pa-4 mx-auto" Style="max-width: 820px; background-color: transparent;">
        <div style="display:flex; align-items:center; gap:12px;">
            <div>
                <MudText Typo="Typo.h5">Intiface</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@ConnectionText</MudText>
            </div>
            <MudSpacer />
            @if (isAdmin)
            {
                <MudButton Variant="Variant.Outlined" Color="@(editMode ? Color.Warning : Color.Default)" OnClick="ToggleEditMode">@(editMode ? "Close Edit" : "Edit Mode")</MudButton>
            }
        </div>

        <MudDivider Class="my-3" />

        @if (!IntifaceService.IntifaceEnabled)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">Intiface is disabled.</MudAlert>
        }

        <MudGrid Class="mb-2">
            <MudItem xs="12" sm="4">
                @if (isLocalHost)
                {
                    @if (!IntifaceService.IntifaceRunning)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Disabled="@(!CanStart)" OnClick="StartIntiface">Start</MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" OnClick="StopIntiface">Stop</MudButton>
                    }
                }
                else
                {
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Disabled="true">Remote View</MudButton>
                }
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudButton Variant="Variant.Filled" Color="@(IntifaceService.FullStop ? Color.Primary : Color.Error)" FullWidth="true" Disabled="@(!IntifaceService.IntifaceRunning)" OnClick="PowerFullStop">
                    @(IntifaceService.FullStop ? "Stopped" : "Full Stop")
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="4">
                @if (isLocalHost)
                {
                    <MudButton Variant="Variant.Outlined" Color="@(IntifaceService.DeviceScanning ? Color.Primary : Color.Default)" FullWidth="true" Disabled="@(!IntifaceService.IntifaceConnected)" OnClick="ToggleDeviceScanning">
                        @(IntifaceService.DeviceScanning ? "Stop Scan" : "Scan")
                    </MudButton>
                }
            </MudItem>
        </MudGrid>

        <Panel_IntifaceReadout />

        <MudPaper Outlined Class="pa-3 mt-3" Style="background-color: transparent;">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Output</MudText>
            <MudSlider T="double" Disabled="@(!IntifaceService.ControlEnabled)" Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Large" Min="0.0" Max="1.0" Step="0.05" @bind-Value="IntifaceService.PatternPowerMulti" />

            @if (IntifaceService.HapticsEnabled)
            {
                <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">Haptic Sensitivity</MudText>
                <MudSlider T="double" Disabled="@(!IntifaceService.ControlEnabled)" Color="Color.Error" Variant="Variant.Filled" Size="Size.Large" Min="0.0" Max="2.0" Step="0.05" @bind-Value="IntifaceService.HapticMultiplier" />
            }

            <div style="display:flex; align-items:center; gap:8px; margin-top:16px; margin-bottom:8px;">
                <MudText Typo="Typo.subtitle1">Pattern</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@PatternLabel(IntifaceService.PatternType)</MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="TogglePatternControls">@(showPatternControls ? "Hide Patterns" : "Show Patterns")</MudButton>
            </div>

            @if (showPatternControls)
            {
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    @foreach (var patternType in AvailablePatterns)
                    {
                        <MudButton Variant="@(IntifaceService.PatternType == patternType ? Variant.Filled : Variant.Outlined)" Color="@(PatternColor(patternType))" OnClick="@(() => SetPattern(patternType))">@PatternLabel(patternType)</MudButton>
                    }
                </div>

                <MudDivider Class="my-3" />
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Rise Speed</MudText>
                        <MudSlider T="double" Min="0.1" Max="8.0" Step="0.1" Disabled="@(!IntifaceService.ControlEnabled)" @bind-Value="IntifaceService.PatSpeedClimb" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Drop Speed</MudText>
                        <MudSlider T="double" Min="0.1" Max="8.0" Step="0.1" Disabled="@(!IntifaceService.ControlEnabled)" @bind-Value="IntifaceService.PatSpeedDrop" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Minimum Power</MudText>
                        <MudSlider T="double" Min="0.0" Max="1.0" Step="0.05" Disabled="@(!IntifaceService.ControlEnabled)" @bind-Value="IntifaceService.PatRandomPowerMin" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Maximum Power</MudText>
                        <MudSlider T="double" Min="0.0" Max="1.0" Step="0.05" Disabled="@(!IntifaceService.ControlEnabled)" @bind-Value="IntifaceService.PatRandomPowerMax" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSwitch T="bool" @bind-Value="IntifaceService.PatUseRandomPower" Label="Randomize Pattern Power" Color="Color.Secondary" Disabled="@(!IntifaceService.ControlEnabled)" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption">Tremor Rate</MudText>
                        <MudSlider T="double" Min="2.0" Max="24.0" Step="0.5" Disabled="@(!IntifaceService.ControlEnabled)" @bind-Value="IntifaceService.PatTremorRate" />
                    </MudItem>
                </MudGrid>
            }
        </MudPaper>

        @if (isAdmin && editMode)
        {
            <MudPaper Outlined Class="pa-3 mt-3" Style="background-color: transparent;">
                <MudText Typo="Typo.h6">Admin Device Editor</MudText>
                <MudDivider Class="my-2" />

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudSwitch T="bool" @bind-Value="IntifaceService.IntifaceEnabled" Label="Intiface Enabled" Color="Color.Success" />
                        <MudSwitch T="bool" @bind-Value="IntifaceService.ControlEnabled" Label="Allow Output" Color="Color.Info" />
                        <MudSwitch T="bool" @bind-Value="IntifaceService.PatternsEnabled" Label="Patterns" Color="Color.Primary" />
                        <MudSwitch T="bool" @bind-Value="IntifaceService.HapticsEnabled" Label="Haptics" Color="Color.Secondary" />
                        <MudSwitch T="bool" @bind-Value="IntifaceService.OSCEnabled" Label="Send OSC Output" Color="Color.Warning" />
                        <MudSwitch T="bool" @bind-Value="IntifaceService.IntifacePointsEnabled" Label="Points Usage" Color="Color.Warning" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" @bind-Value="IntifaceService.IntifaceServerAddress" Label="Intiface Server" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudTextField T="string" @bind-Value="IntifaceService.OutputParameterName" Label="OSC Output Parameter" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudNumericField T="double" @bind-Value="IntifaceService.PatternExponent" Label="Output Exponent" Min="@DoubleMinPositive" Max="@DoubleMaxTen" Step="@DoubleStepMedium" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="mt-2" OnClick="SaveIntifaceConfig">Save Device Config</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined Class="pa-3 mt-3" Style="background-color: transparent;">
                <MudText Typo="Typo.h6">Pattern Settings</MudText>
                <MudDivider Class="my-2" />
                <MudGrid>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatRandomOnTimeMin" Label="On Min Seconds" Min="0.0" Max="30.0" Step="0.1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatRandomOnTimeMax" Label="On Max Seconds" Min="0.0" Max="30.0" Step="0.1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatRandomOffTimeMin" Label="Off Min Seconds" Min="0.0" Max="30.0" Step="0.1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatRandomOffTimeMax" Label="Off Max Seconds" Min="0.0" Max="30.0" Step="0.1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatSpeedClimb" Label="Rise Speed" Min="0.1" Max="20.0" Step="0.1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatSpeedDrop" Label="Drop Speed" Min="0.1" Max="20.0" Step="0.1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatRandomPowerMin" Label="Min Power" Min="0.0" Max="1.0" Step="0.05" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatRandomPowerMax" Label="Max Power" Min="0.0" Max="1.0" Step="0.05" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="int" @bind-Value="IntifaceService.PatBurstCount" Label="Burst Count" Min="1" Max="20" Step="1" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatBurstSpacing" Label="Burst Spacing" Min="0.03" Max="2.0" Step="0.05" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatTremorRate" Label="Tremor Rate" Min="1.0" Max="40.0" Step="0.5" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="6" sm="3"><MudNumericField T="double" @bind-Value="IntifaceService.PatTremorDepth" Label="Tremor Depth" Min="0.0" Max="1.0" Step="0.05" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined Class="pa-3 mt-3" Style="background-color: transparent;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <MudText Typo="Typo.h6">Devices</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="AddDevice">Add Device</MudButton>
                </div>
                <MudDivider Class="my-2" />
                <div style="max-height: 320px; overflow-y: auto; padding-right: 6px;">
                    @foreach (var device in IntifaceService.ConfigedDevices.ToList())
                    {
                        <MudPaper Outlined Class="pa-3 mb-2" Style="background-color: rgba(255,255,255,.03);">
                            <MudGrid>
                                <MudItem xs="12" sm="3">
                                    <MudSwitch T="bool" @bind-Value="device.Enabled" Label="Enabled" Color="Color.Success" />
                                    <MudText Typo="Typo.caption" Color="@(device.Connected ? Color.Success : Color.Secondary)">@(device.Connected ? "Connected" : "Not Connected")</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTextField T="string" @bind-Value="device.DisplayName" Label="Display Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTextField T="string" @bind-Value="device.Name" Label="Device Match Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="1" Style="display:flex; align-items:center;">
                                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => RemoveDevice(device))">Remove</MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                </div>
            </MudPaper>

            <MudPaper Outlined Class="pa-3 mt-3" Style="background-color: transparent;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <MudText Typo="Typo.h6">Haptic Input Sources</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="AddHapticInput">Add Input</MudButton>
                </div>
                <MudDivider Class="my-2" />
                <div style="max-height: 460px; overflow-y: auto; padding-right: 6px;">
                    @foreach (var input in IntifaceService.HapticInputs.ToList())
                    {
                        <MudPaper Outlined Class="pa-3 mb-2" Style="background-color: rgba(255,255,255,.03);">
                            <MudGrid>
                                <MudItem xs="12" sm="2">
                                    <MudSwitch T="bool" @bind-Value="input.Enabled" Label="Enabled" Color="Color.Success" />
                                    <MudText Typo="Typo.caption">Value: @input.Parameter.Value.ToString("0.###")</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    <MudTextField T="string" Value="@ParameterName(input)" ValueChanged="@((string value) => SetHapticParameterName(input, value))" Label="OSC Parameter" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="2">
                                    <MudSelect T="ParameterType" Value="@input.Parameter.Type" ValueChanged="@((ParameterType value) => SetHapticType(input, value))" Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (var type in Enum.GetValues<ParameterType>())
                                        {
                                            <MudSelectItem T="ParameterType" Value="@type">@type.ToString()</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="6" sm="2">
                                    <MudNumericField T="float" @bind-Value="input.Parameter.Value" Label="Current Value" Min="@FloatMinZero" Max="@FloatMaxTen" Step="@FloatStepSmall" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="2">
                                    <MudTextField T="string" Value="@GetHapticPreview(input)" Label="Output Preview" ReadOnly="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="2">
                                    <MudNumericField T="float" @bind-Value="input.Min" Label="Min" Step="@FloatStepSmall" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="2">
                                    <MudNumericField T="float" @bind-Value="input.Max" Label="Max" Step="@FloatStepSmall" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudNumericField T="float" @bind-Value="input.Exponent" Label="Exponent" Min="@FloatMinPositive" Max="@FloatMaxTen" Step="@FloatStepMedium" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudNumericField T="float" @bind-Value="input.Multiplier" Label="Multiplier" Min="@FloatMinZero" Max="@FloatMaxTen" Step="@FloatStepMedium" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudNumericField T="float" @bind-Value="input.Influence" Label="Influence" Min="@FloatMinZero" Max="@FloatMaxTen" Step="@FloatStepMedium" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="6" sm="3" Style="display:flex; align-items:center; justify-content:flex-end;">
                                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => RemoveHapticInput(input))">Remove</MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                </div>
            </MudPaper>
        }
    </MudPaper>
}
